{
  "name": "@workbench/cli",
  "version": "0.1.0",
  "description": "Infrastructure CLI and MCP server entry point for AI Agent Workbench.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "workbench": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "resources/skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "mcp:dev": "node dist/cli.js mcp --dev",
    "lint": "biome check src test",
    "format": "biome format src test --write",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.0",
    "yaml": "^2.7.0",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.15.17",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
